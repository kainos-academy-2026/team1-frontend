{
	"name": "team1-frontend",
	"version": "1.0.0",
	"description": "Team1 Frontend",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc && cp -r src/views dist/views",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:bdd": "API_BASE_URL=http://localhost:3001 JWT_SECRET=bdd-test-secret tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js tests/bdd/features/**/*.feature --import tests/bdd/steps/**/*.ts --format progress --format json:test-reports/cucumber-$(date +%F).json",
		"test:ui:e2e": "playwright test",
		"test:framework": "npm run test && npm run test:bdd && npm run test:ui:e2e",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"ci:check": "biome ci ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kainos-academy-2026/team1-frontend.git"
	},
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/kainos-academy-2026/team1-frontend/issues"
	},
	"homepage": "https://github.com/kainos-academy-2026/team1-frontend#readme",
	"dependencies": {
		"@types/nunjucks": "^3.2.6",
		"axios": "^1.18.1",
		"cookie-parser": "^1.4.7",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"helmet": "^8.3.0",
		"jose": "^6.2.3",
		"nunjucks": "^3.2.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@biomejs/biome": "^2.5.2",
		"@cucumber/cucumber": "^13.2.0",
		"@playwright/test": "^1.61.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^26.1.0",
		"@types/nunjucks": "^3.2.6",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"supertest": "^7.2.2",
		"ts-node": "^10.9.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	}
}
