{% macro fieldMacro(config) %}
    {% set errorMessage = config.errorMessage %}
    {% set hintId = config.hintId %}
    {% set errorId = config.errorId or config.id + '-error' %}
    {% set describedBy = '' %}

    {% if hintId %}
        {% set describedBy = describedBy + hintId %}
    {% endif %}

    {% if errorMessage %}
        {% if describedBy %}
            {% set describedBy = describedBy + ' ' %}
        {% endif %}
        {% set describedBy = describedBy + errorId %}
    {% endif %}

    <div class="{{ config.wrapperClass or '' }}">
        <label for="{{ config.id }}">{{ config.label }}</label>
        <input
            id="{{ config.id }}"
            name="{{ config.name }}"
            type="{{ config.type or 'text' }}"
            {% if config.required %}required{% endif %}
            {% if config.autocomplete %}autocomplete="{{ config.autocomplete }}"{% endif %}
            {% if config.minlength %}minlength="{{ config.minlength }}"{% endif %}
            {% if config.pattern %}pattern="{{ config.pattern }}"{% endif %}
            {% if config.value %}value="{{ config.value }}"{% endif %}
            {% if describedBy %}aria-describedby="{{ describedBy }}"{% endif %}
            {% if errorMessage %}aria-invalid="true"{% endif %}
            {% if config.inputClass %}class="{{ config.inputClass }}"{% endif %}
        >

        {% if config.hintText %}
            <p id="{{ hintId }}" class="{{ config.hintClass or '' }}">{{ config.hintText }}</p>
        {% endif %}

        {% if errorMessage %}
            <p id="{{ errorId }}" class="{{ config.errorClass or '' }}" role="alert">{{ errorMessage }}</p>
        {% endif %}
    </div>
{% endmacro %}
