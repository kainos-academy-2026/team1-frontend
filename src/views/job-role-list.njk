{% extends "layouts/base.njk" %}
{% block content %}
    <a class="back-btn" href="/" aria-label="Back to home">&lt;</a>
    <h1 class="job-listings-title">Current opportunities...</h1>
    {% if jobRoles and jobRoles.length > 0 %}
        <section class="job-listings">
            {% for role in jobRoles %}
                <a class="job-card-link" href="/job-roles/{{ role.jobRoleId }}">
                    <article class="job-card">
                        <h2 class="job-card-title">{{ role.roleName }}</h2>
                        <div class="job-card-body">
                            <span>{{ role.bandName }} - {{ role.capabilityName }}</span>
                            <span>{{ role.location }}</span>
                        </div>
                        <p class="job-card-closing">Closing date: {{ role.closingDate }}</p>
                    </article>
                </a>
            {% endfor %}
        </section>
    {% else %}
        <p>No job roles are currently available.</p>
    {% endif %}
{% endblock %}