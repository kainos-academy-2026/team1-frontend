{% extends "layouts/base.njk" %}
{% block content %}
    <a class="back-btn" href="/" aria-label="Back to home">&lt;</a>
    <h1 class="job-listings-title">Current opportunities...</h1>
    {% if jobRoles and jobRoles.length > 0 %}
        <section class="job-listings">
            {% for role in jobRoles %}
                <a class="job-card-link" href="/job-roles/{{ role.jobRoleId }}">
                    <article class="job-card">
                        <h2 class="job-card-title">{{ role.roleName }}</h2>
                        <div class="job-card-body">
                            <span>{{ role.bandName }} - {{ role.capabilityName }}</span>
                            <span>{{ role.location }}</span>
                        </div>
                        <p class="job-card-closing">Closing date: {{ role.closingDate }}</p>
                    </article>
                </a>
            {% endfor %}
        </section>
        <nav class="pagination" aria-label="Job roles pages">
            <a
                class="pagination-link{% if not hasPrevious %} is-disabled{% endif %}"
                href="{% if hasPrevious %}/job-roles?limit={{ pageSize }}&offset={{ firstOffset }}{% else %}#{% endif %}"
                {% if not hasPrevious %}aria-disabled="true" tabindex="-1"{% endif %}
            >
                First
            </a>
            <a
                class="pagination-link{% if not hasPrevious %} is-disabled{% endif %}"
                href="{% if hasPrevious %}/job-roles?limit={{ pageSize }}&offset={{ previousOffset }}{% else %}#{% endif %}"
                {% if not hasPrevious %}aria-disabled="true" tabindex="-1"{% endif %}
            >
                Previous
            </a>
            <span class="pagination-summary">Page {{ currentPage }} of {{ totalPages }}</span>
            <a
                class="pagination-link{% if not hasNext %} is-disabled{% endif %}"
                href="{% if hasNext %}/job-roles?limit={{ pageSize }}&offset={{ nextOffset }}{% else %}#{% endif %}"
                {% if not hasNext %}aria-disabled="true" tabindex="-1"{% endif %}
            >
                Next
            </a>
            <a
                class="pagination-link{% if not hasNext %} is-disabled{% endif %}"
                href="{% if hasNext %}/job-roles?limit={{ pageSize }}&offset={{ lastOffset }}{% else %}#{% endif %}"
                {% if not hasNext %}aria-disabled="true" tabindex="-1"{% endif %}
            >
                Last
            </a>
        </nav>
    {% else %}
        <p>No job roles are currently available.</p>
    {% endif %}
{% endblock %}
