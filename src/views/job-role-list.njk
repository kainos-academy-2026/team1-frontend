<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Job Roles</title>
	</head>
	<body>
		<h1>Job Roles</h1>
		{% if jobRoles.length %}
			<table>
				<thead>
					<tr>
						<th>Role</th>
						<th>Location</th>
						<th>Capability</th>
						<th>Band</th>
						<th>Closing Date</th>
					</tr>
				</thead>
				<tbody>
					{% for role in jobRoles %}
						<tr>
							<td>{{ role.name }}</td>
							<td>{{ role.location }}</td>
							<td>{{ role.capability }}</td>
							<td>{{ role.band }}</td>
							<td>{{ role.closingDate }}</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		{% else %}
			<p>No job roles are currently available.</p>
		{% endif %}
	</body>
</html>
