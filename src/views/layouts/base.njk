<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Kainos</title>
        <link rel="icon" href="/assets/images/favicon.svg">
        <link rel="stylesheet" href="/assets/style.css">
    </head>
    <body>
        <header class="site-header">
            <div class="brand">
                <a href="/" class="brand-link">
                    <img src="/assets/images/kainos_logo.svg" alt="Kainos logo" class="brand-logo">
                </a>
            </div>
            <span class="brand-name">Kainos Careers</span>
            <nav class="site-nav" aria-label="Main navigation">
                <ul>
                    <li>
                        <a href="/">Home</a>
                    </li>
                    <li id="login-nav-item">
                        <a href="/login">Login</a>
                    </li>
                    <li id="registration-nav-item">
                        <a href="/registration">Register</a>
                    </li>
                    <li id="logout-nav-item" hidden>
                        <a href="/login?loggedOut=1" onclick="sessionStorage.removeItem('loginToken');">Logout</a>
                    </li>
                </ul>
            </nav>
        </header>
        <main class="page-content"> {% block content %}{% endblock %}
            </main>
            <footer class="site-footer">
                <img src="/assets/images/kainos_logo.svg" alt="Kainos logo" class="footer-logo">
                <p>Contact us at info@kainos.com
                </p>
            </footer>
        </body>
    </html>