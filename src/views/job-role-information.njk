{% extends "layouts/base.njk" %}
{% block content %}
	<a class="back-btn" href="/job-roles" aria-label="Back to job roles">Back</a>
	<h1 class="job-listings-title">{{ jobRole.roleName }}</h1>
	<article class="job-detail-card">
		<section class="job-detail-section" aria-labelledby="job-description-heading">
			<h2 id="job-description-heading" class="job-detail-heading">Description</h2>
			<p class="job-detail-text">{{ jobRole.description }}</p>
		</section>

		<section class="job-detail-section" aria-labelledby="job-responsibilities-heading">
			<h2 id="job-responsibilities-heading" class="job-detail-heading">Responsibilities</h2>
			<p class="job-detail-text">{{ jobRole.responsibilities }}</p>
		</section>

		<dl class="job-detail-meta">
			<dt>Job Specification</dt>
			<dd>
				<a class="job-detail-link" href="{{ jobRole.sharepointUrl }}" target="_blank" rel="noopener noreferrer">
					View Job Specification (opens in a new tab)
				</a>
			</dd>

			<dt>Location</dt>
			<dd>{{ jobRole.location }}</dd>

			<dt>Capability</dt>
			<dd>{{ jobRole.capabilityName }}</dd>

			<dt>Band</dt>
			<dd>{{ jobRole.bandName }}</dd>

			<dt>Closing Date</dt>
			<dd>{{ jobRole.closingDate }}</dd>

			<dt>Status</dt>
			<dd>{{ jobRole.status | capitalize }}</dd>

			<dt>Open Positions</dt>
			<dd>{{ jobRole.numberOfOpenPositions }}</dd>
		</dl>

		{% if jobRole.status == "open" and jobRole.numberOfOpenPositions > 0 %}
			<form action="/job-roles/{{ jobRole.jobRoleId }}/apply" method="get">
				<button type="submit" class="btn btn-primary apply-btn">Apply for this role</button>
			</form>
		{% endif %}
	</article>
{% endblock %}
