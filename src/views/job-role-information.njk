<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ jobRole.roleName }}</title>
	</head>
	<body>
		<a href="/job-roles">Back to Job Roles</a>
		<h1>{{ jobRole.roleName }}</h1>
		<h2>Description</h2>
		<p>{{ jobRole.description or 'Description not yet available.' }}</p>

		<h2>Responsibilities</h2>
		<p>{{ jobRole.responsibilities or 'Responsibilities not yet available.' }}</p>

		<dl>
			<dt>Job Specification</dt>
			{% if jobRole.sharepointUrl %}
				<dd>
					<a href="{{ jobRole.sharepointUrl }}" target="_blank" rel="noopener noreferrer">
						View Job Specification (opens in a new tab)
					</a>
				</dd>
			{% else %}
				<dd>Job specification not yet available.</dd>
			{% endif %}

			<dt>Location</dt>
			<dd>{{ jobRole.location }}</dd>

			<dt>Capability</dt>
			<dd>{{ jobRole.capability }}</dd>

			<dt>Band</dt>
			<dd>{{ jobRole.band }}</dd>

			<dt>Closing Date</dt>
			<dd>{{ jobRole.closingDate }}</dd>

			<dt>Status</dt>
			<dd>{{ jobRole.status | capitalize }}</dd>

			<dt>Open Positions</dt>
			<dd>{{ jobRole.numberOfOpenPositions }}</dd>
		</dl>
	</body>
</html>
