{% extends "layouts/base.njk" %}
{% block content %}
	<a class="back-btn" href="/job-roles" aria-label="Back to job roles">Back</a>
	<h1 class="job-listings-title">{{ jobRole.roleName }}</h1>
	<article class="job-detail-card">
		<section class="job-detail-section" aria-labelledby="job-description-heading">
			<h2 id="job-description-heading" class="job-detail-heading">Description</h2>
			<p class="job-detail-text">{{ jobRole.description }}</p>
		</section>

		<section class="job-detail-section" aria-labelledby="job-responsibilities-heading">
			<h2 id="job-responsibilities-heading" class="job-detail-heading">Responsibilities</h2>
			<p class="job-detail-text">{{ jobRole.responsibilities }}</p>
		</section>

		<dl class="job-detail-meta">
			<dt>Job Specification</dt>
			<dd>
				<a class="job-detail-link" href="{{ jobRole.sharepointUrl }}" target="_blank" rel="noopener noreferrer">
					View Job Specification (opens in a new tab)
				</a>
			</dd>

			<dt>Location</dt>
			<dd>{{ jobRole.location }}</dd>

			<dt>Capability</dt>
			<dd>{{ jobRole.capabilityName }}</dd>

			<dt>Band</dt>
			<dd>{{ jobRole.bandName }}</dd>

			<dt>Closing Date</dt>
			<dd>{{ jobRole.closingDate }}</dd>

			<dt>Status</dt>
			<dd>{{ jobRole.status | capitalize }}</dd>

			<dt>Open Positions</dt>
			<dd>{{ jobRole.numberOfOpenPositions }}</dd>
		</dl>

		{% if jobRole.status == "open" and jobRole.numberOfOpenPositions > 0 %}
			<form action="/job-roles/{{ jobRole.jobRoleId }}/apply" method="get">
				<button type="submit" class="btn btn-primary apply-btn">Apply for this role</button>
			</form>
		{% endif %}

		{% if user and user.isAdmin %}
			<section class="job-detail-section" aria-labelledby="applications-heading">
				<h2 id="applications-heading" class="job-detail-heading">Applications</h2>

				{% if jobRole.applications.length > 0 %}
					<div class="applications-table-wrapper">
						<table class="applications-table">
							<thead>
								<tr>
									<th scope="col">Username</th>
									<th scope="col">Status</th>
									<th scope="col">Actions</th>
								</tr>
							</thead>
							<tbody>
								{% for application in jobRole.applications %}
									<tr>
										<td>
											<a
												class="job-detail-link"
												href="{{ application.cvUrl }}"
												target="_blank"
												rel="noopener noreferrer"
											>
												{{ application.username }}
											</a>
										</td>
										<td class="applications-status">{{ application.status }}</td>
										<td>
											{% if application.canHire or application.canReject %}
												<div class="application-actions">
													{% if application.canHire %}
														<form
															action="/job-roles/{{ jobRole.jobRoleId }}/applications/{{ application.applicationId }}/hire"
															method="post"
															class="application-action-form"
															data-confirm-message="Are you sure you want to hire this applicant?"
														>
															<button class="application-action-link" type="submit">Hire</button>
														</form>
													{% endif %}
													{% if application.canReject %}
														<form
															action="/job-roles/{{ jobRole.jobRoleId }}/applications/{{ application.applicationId }}/reject"
															method="post"
															class="application-action-form"
															data-confirm-message="Are you sure you want to reject this applicant?"
														>
															<button class="application-action-link" type="submit">Reject</button>
														</form>
													{% endif %}
												</div>
											{% else %}
												<span class="applications-no-actions">-</span>
											{% endif %}
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% else %}
					<p class="job-detail-text">There are no applications for this role yet.</p>
				{% endif %}
			</section>
		{% endif %}
	</article>

	{% if user and user.isAdmin %}
		<script src="/assets/job-role-applications.js"></script>
	{% endif %}
{% endblock %}
