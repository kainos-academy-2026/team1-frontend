{% extends "layouts/base.njk" %}
{% from "macros/field-macro.njk" import field %}
{% block content %}
    <section class="login-page">
        <div class="login-card">
            <p class="login-eyebrow">Create profile</p>
            <h1>Create an account</h1>
            <p class="login-intro">Use your email address and a strong password to register.</p>

            {% if formError %}
                <p class="field-error" role="alert">{{ formError }}</p>
            {% endif %}

            <form class="login-form" method="post" action="/registration">
                {{ field('email', 'Email', 'email', 'name@example.com', formData.email or '', errors, 'email') }}

                {{ field('password', 'Password', 'password', '', '', errors, 'new-password') }}

                <button class="login-submit" type="submit">Register</button>
            </form>
        </div>
    </section>
{% endblock %}