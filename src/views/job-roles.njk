<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Job Roles</title>
	</head>
	<body>
		<h1>Job Roles</h1>
		{% if jobRoles.length %}
			<ul>
				{% for role in jobRoles %}
					<li>{{ role.name }}</li>
				{% endfor %}
			</ul>
		{% else %}
			<p>No job roles are currently available.</p>
		{% endif %}
	</body>
</html>
